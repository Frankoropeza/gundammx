---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página no encontrada" description="La página que buscas no existe.">
  <section class="max-w-2xl mx-auto px-4 py-32 text-center">
    <p class="font-display text-8xl font-black text-gundam-red mb-4">404</p>
    <h1 class="font-display text-2xl font-bold text-white mb-4">Unidad no encontrada</h1>
    <p class="text-gundam-text/60 mb-8">
      Parece que este Mobile Suit fue destruido en combate. La página que buscas no existe.
    </p>
    <a
      href="/"
      class="inline-flex items-center px-6 py-3 bg-gundam-blue text-white font-bold rounded-lg hover:bg-gundam-blue/80 transition-colors"
    >
      Volver a la base
    </a>
  </section>
</BaseLayout>
