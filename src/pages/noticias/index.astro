---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const noticias = await getCollection('noticias', ({ data }) => !data.draft);
const sortedNoticias = noticias.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Noticias" description="Las últimas noticias del mundo Gundam y Gunpla en México y el mundo.">
  <section class="max-w-7xl mx-auto px-4 py-12">
    <header class="mb-10">
      <h1 class="font-display font-bold text-3xl md:text-4xl text-white mb-2">Noticias</h1>
      <p class="text-gundam-text/60">Lo último del mundo Gundam y Gunpla.</p>
    </header>

    {sortedNoticias.length === 0 ? (
      <p class="text-gundam-text/40 text-center py-20">No hay noticias publicadas aún.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedNoticias.map((noticia) => (
          <a
            href={`/noticias/${noticia.slug}`}
            class="block bg-gundam-blue/10 border border-gundam-blue/20 rounded-xl p-6 hover:border-gundam-gold/40 transition-colors group"
          >
            <span class="inline-block bg-gundam-red text-white text-xs font-medium px-2 py-0.5 rounded-full mb-3">
              {noticia.data.category}
            </span>
            <h2 class="font-display font-bold text-white text-lg mb-2 group-hover:text-gundam-gold transition-colors">
              {noticia.data.title}
            </h2>
            <p class="text-sm text-gundam-text/60 mb-4 line-clamp-3">{noticia.data.description}</p>
            <div class="flex items-center gap-3 text-xs text-gundam-text/40">
              <span>{noticia.data.author}</span>
              <span>•</span>
              <time datetime={noticia.data.pubDate.toISOString()}>
                {noticia.data.pubDate.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
