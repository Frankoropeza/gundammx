---
interface Props {
  title: string;
  grade: string;
  series: string;
  scale: string;
  price: number;
  difficulty: number;
  description: string;
  image?: string;
}

const { title, grade, series, scale, price, difficulty, description, image } = Astro.props;

const gradeColors: Record<string, string> = {
  HG: 'bg-green-600',
  MG: 'bg-gundam-blue',
  RG: 'bg-purple-600',
  PG: 'bg-gundam-red',
  SD: 'bg-orange-500',
};

const difficultyStars = Array.from({ length: 5 }, (_, i) => i < difficulty);
---

<div class="bg-gundam-blue/10 border border-gundam-blue/20 rounded-xl overflow-hidden hover:border-gundam-gold/40 transition-colors group">
  {image ? (
    <img src={image} alt={title} class="w-full h-48 object-cover" />
  ) : (
    <div class="w-full h-48 bg-gundam-blue/20 flex items-center justify-center">
      <img src="/favicon.svg" alt="Gundam MX" class="w-16 h-16 opacity-30" />
    </div>
  )}

  <div class="p-5">
    <div class="flex items-center gap-2 mb-3">
      <span class:list={['text-xs font-bold text-white px-2 py-0.5 rounded', gradeColors[grade] || 'bg-gray-600']}>
        {grade}
      </span>
      <span class="text-xs text-gundam-text/50">{scale}</span>
    </div>

    <h3 class="font-display font-bold text-white text-lg mb-1 group-hover:text-gundam-gold transition-colors">
      {title}
    </h3>
    <p class="text-xs text-gundam-text/50 mb-3">{series}</p>
    <p class="text-sm text-gundam-text/70 mb-4 line-clamp-2">{description}</p>

    <div class="flex items-center justify-between">
      <span class="font-bold text-gundam-gold text-lg">${price.toLocaleString('es-MX')} MXN</span>
      <div class="flex gap-0.5" title={`Dificultad: ${difficulty}/5`}>
        {difficultyStars.map((filled) => (
          <svg class:list={['w-4 h-4', filled ? 'text-gundam-gold' : 'text-gundam-text/20']} fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
    </div>
  </div>
</div>
