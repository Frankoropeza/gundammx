---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  author?: string;
}

const props = Astro.props;
---

<!doctype html>
<html lang="es-MX" class="scroll-smooth">
  <head>
    <SEO {...props} />
  </head>
  <body class="bg-gundam-dark text-gundam-text min-h-screen flex flex-col antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
