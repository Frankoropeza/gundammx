---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  category?: string;
  tags?: string[];
}

const { title, description, pubDate, author, category, tags } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: {
    '@type': 'Organization',
    name: 'Gundam MX',
    logo: { '@type': 'ImageObject', url: 'https://gundammx.com/favicon.svg' },
  },
};
---

<BaseLayout title={title} description={description} type="article" pubDate={pubDate} author={author}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-10">
      {category && (
        <span class="inline-block bg-gundam-red text-white text-sm font-medium px-3 py-1 rounded-full mb-4">
          {category}
        </span>
      )}
      <h1 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-gundam-text/60">
        <span>{author}</span>
        <span>•</span>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs bg-gundam-blue/30 text-gundam-gold px-2 py-1 rounded">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:font-display prose-headings:text-white
      prose-a:text-gundam-gold prose-a:no-underline hover:prose-a:underline
      prose-strong:text-white
      prose-code:text-gundam-gold">
      <slot />
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
